# Neon Postgres connection string. Provisioned by the Vercel + Neon
# integration; copy the value from the Vercel project's environment variables.
DATABASE_URL="postgres://user:password@host/db?sslmode=require"

# Secret used to sign admin session cookies (HMAC-SHA256). Must be identical
# across every environment that should share a login. Generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="replace-with-a-long-random-string"

# --- Optional: transactional email (booking confirmations & owner alerts) ---
# Without a key, the app runs fine and logs skipped sends instead of emailing.
# Create a free account at https://resend.com, then verify your domain and use
# a sender on it (until then the default onboarding sender only delivers to
# the Resend account owner).
RESEND_API_KEY=""
RESEND_FROM="Vine Cliff <onboarding@resend.dev>"

# Absolute origin used in email links and iCal URLs. Defaults to the canonical
# production URL from lib/site.ts; set this on previews if links should point
# elsewhere.
NEXT_PUBLIC_SITE_URL=""
