# Neon Postgres connection string. Provisioned by the Vercel + Neon
# integration; copy the value from the Vercel project's environment variables.
DATABASE_URL="postgres://user:password@host/db?sslmode=require"

# Secret used to sign admin session cookies (HMAC-SHA256). Must be identical
# across every environment that should share a login. Generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="replace-with-a-long-random-string"
